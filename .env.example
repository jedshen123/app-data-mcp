# PostgreSQL metadata catalog. New synchronized assets are private until an administrator publishes them.
METADATA_TABLE=app_data_mcp_assets
METADATA_DEFAULT_PUBLISHED=false
MCP_TOOLS_TABLE=app_data_mcp_tools
MCP_SETTINGS_TABLE=app_data_mcp_settings

# HTTP transport. Use 127.0.0.1 for local use; use 0.0.0.0 only behind auth/network controls.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000

# Optional legacy shared token for HTTP mode. Prefer personal tokens generated by /auth/metabase/login.
MCP_HTTP_BEARER_TOKEN=

# Public URL of this MCP service, used in reauth_required responses.
# Example: https://your-mcp-host.example.com
APP_DATA_MCP_PUBLIC_BASE_URL=
# Require every data request to carry a personal MCP token mapped to a Metabase account.
APP_DATA_REQUIRE_AUTH_TOKEN=true
# Administrator sessions for /admin. Login requires Metabase is_superuser=true.
# Persistent sessions survive service restarts and do not expire server-side until logout/revocation.
ADMIN_SESSION_PERSISTENT=true
ADMIN_SESSION_TTL_HOURS=168
ADMIN_SESSION_TABLE=app_data_mcp_admin_sessions

# Data volume guardrails. Keep responses small enough for AI clients.
DATA_DEFAULT_SEARCH_LIMIT=10
DATA_MAX_SEARCH_LIMIT=50
DATA_DEFAULT_RESULT_ROW_LIMIT=100
DATA_MAX_RESULT_ROW_LIMIT=500
DATA_MAX_RESPONSE_BYTES=1000000

# Metadata freshness. catalog_status reports stale snapshots when these intervals are exceeded.
# Recommended: Metabase every 1-6h depending on permission change frequency; PostHog every 12h.
METABASE_METADATA_SYNC_INTERVAL_HOURS=6
METABASE_PERMISSION_SYNC_INTERVAL_HOURS=6
POSTHOG_METADATA_SYNC_INTERVAL_HOURS=12

# PostgreSQL is shared by metadata and audit logs. The service automatically creates both tables.
# MCP tool calls are logged to DB_SCHEMA.AUDIT_LOG_TABLE.
AUDIT_LOG_ENABLED=true
AUDIT_LOG_TABLE=app_data_mcp_audit_logs
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=superset
DB_PASSWORD=123456
DB_NAME=cubecore
DB_SCHEMA=public
# Enable TLS for cloud PostgreSQL services such as Amazon RDS.
DB_SSL=false
# Keep verification enabled in production and provide the provider CA bundle.
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_FILE=

# Metabase API config. Do not put secrets in the metadata table.
METABASE_BASE_URL=https://metabase.example.com
# Optional public URL used in returned source links. Keep METABASE_BASE_URL for server-side API access.
METABASE_PUBLIC_URL=https://metabase.example.com
METABASE_LOGIN_URL=https://app-data.luteos.site
# Each personal MCP token maps to the Metabase account that completed authorization.
METABASE_AUTH_MODE=user-session
METABASE_ALLOW_SERVICE_FALLBACK=false
# Compatibility metadata only; MCP no longer rejects a stored Session based on this local timestamp.
# Metabase may still reject its own Session, in which case that account must reauthorize.
METABASE_SESSION_TTL_HOURS=168
APP_DATA_SESSION_FILE=.data/metabase-sessions.json
METABASE_API_KEY=
# Alternative if your Metabase does not use API keys yet.
# The connector will call POST /api/session and then use X-Metabase-Session.
METABASE_USER=
METABASE_PASS=
# Backward-compatible aliases also supported:
METABASE_USERNAME=
METABASE_PASSWORD=

# PostHog API config. Use a personal/project API key with the least required permissions.
POSTHOG_BASE_URL=https://posthog.example.com
POSTHOG_PROJECT_ID=
# Required for private read APIs such as dashboards and insights.
# This must be a Personal API key, not the Project API key / project token.
POSTHOG_PERSONAL_API_KEY=
# Backward-compatible alias also supported:
POSTHOG_API_KEY=

# StarRocks read-only SQL connector. Use a dedicated account with SELECT-only permissions.
# StarRocks FE query port is usually 9030.
STARROCKS_HOST=127.0.0.1
STARROCKS_PORT=9030
STARROCKS_USER=app_data_mcp_reader
STARROCKS_PASSWORD=
STARROCKS_DATABASE=
STARROCKS_CONNECTION_LIMIT=10
STARROCKS_CONNECT_TIMEOUT_MS=10000
STARROCKS_QUERY_TIMEOUT_MS=30000
STARROCKS_MAX_SQL_LENGTH=50000
STARROCKS_SSL=false
STARROCKS_SSL_REJECT_UNAUTHORIZED=true
